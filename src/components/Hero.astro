---
import { config } from '../data/config';
---
<section class={`relative overflow-hidden ${config.heroStyle === 'background' ? 'min-h-[85vh] flex items-center py-20' : 'py-24 sm:py-32 bg-white'}`}>
  {config.heroStyle === 'background' ? (
    <>
      <div class="absolute inset-0 z-0">
        <img 
          src={config.hero.image} 
          alt="Instalaciones Sirga" 
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-secondary/90 via-secondary/70 to-transparent"></div>
      </div>
    </>
  ) : (
    <>
      <!-- Decorative Background -->
      <div class="absolute -top-32 -right-32 w-[600px] h-[600px] bg-primary/10 rounded-full blur-3xl opacity-70 pointer-events-none"></div>
      <div class="absolute top-1/2 -left-32 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-3xl opacity-70 pointer-events-none"></div>
    </>
  )}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class={`${config.heroStyle === 'background' ? 'text-left max-w-2xl' : 'text-center max-w-3xl mx-auto'}`}>
      <span class={`js-hero-element animate-safari inline-block py-1.5 px-4 rounded-full font-semibold text-sm mb-8 border tracking-wide uppercase ${config.heroStyle === 'background' ? 'bg-primary/20 text-primary border-primary/30' : 'bg-primary/10 text-primary border-primary/20'}`}>
        {config.hero.badge}
      </span>
      <h1 class={`js-hero-element animate-safari text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight mb-8 leading-[1.1] text-balance ${config.heroStyle === 'background' ? 'text-white' : 'text-secondary'}`}>
        <Fragment set:html={config.hero.title} />
      </h1>
      <p class={`js-hero-element animate-safari text-lg sm:text-xl mb-10 leading-relaxed text-balance ${config.heroStyle === 'background' ? 'text-gray-200' : 'text-gray-600'}`}>
        {config.hero.description}
      </p>
      
      <div class={`flex flex-col sm:flex-row gap-4 ${config.heroStyle === 'background' ? 'justify-start' : 'justify-center items-center'}`}>
        <a href="#contacto" class="js-hero-btn animate-safari js-reserva-btn inline-flex items-center justify-center px-8 py-4 border border-transparent text-base font-semibold rounded-full text-white bg-accent shadow-lg shadow-accent/30 w-full sm:w-auto">
          Reserva Cita
        </a>
        <a href="#servicios" class={`js-hero-btn animate-safari inline-flex items-center justify-center px-8 py-4 border text-base font-semibold rounded-full shadow-sm transition-all duration-300 w-full sm:w-auto ${config.heroStyle === 'background' ? 'border-white/30 text-white bg-white/10 hover:bg-white/20 backdrop-blur-sm' : 'border-gray-200 text-secondary bg-white hover:bg-gray-50'}`}>
          Ver Servicios
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  const heroElements = document.querySelectorAll(".js-hero-element");
  const heroBtns = document.querySelectorAll(".js-hero-btn");

  /**
   * 🎓 EXPLICACIÓN GSAP (ANIMACIÓN DE ENTRADA HERO):
   * 1. gsap.set(): Configura el estado INICIAL de manera instantánea (hace caer los textos 40px hacia abajo con 'y: 40' y los vuelve invisibles 'opacity: 0').
   * 2. gsap.to(): Anima los elementos fluídamente hacia su estado normal (y: 0, opacity: 1).
   * 
   * ¿Qué hace 'stagger'?
   * En lugar de animar todos los textos de golpe a la vez, 'stagger: 0.15' crea un efecto de cascada. 
   * Cada bloque de texto espera 0.15 segundos antes de salir después del bloque anterior.
   */
  if (heroElements.length > 0) {
    gsap.set(heroElements, { y: 40, opacity: 0 });
    gsap.to(heroElements, {
      y: 0,
      opacity: 1,
      duration: 1,
      stagger: 0.15,
      ease: "power3.out",
      delay: 0.1,
      force3D: true
    });
  }

  if (heroBtns.length > 0) {
    gsap.set(heroBtns, { y: 20, opacity: 0 });
    gsap.to(heroBtns, {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.1,
      ease: "power2.out",
      delay: 0.6,
      force3D: true
    });
  }
</script>
