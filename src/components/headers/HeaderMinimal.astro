---
import { config } from '../../data/config';
---
<header class="js-header fixed top-0 left-0 w-full z-[100] bg-white/95 backdrop-blur-md border-b border-gray-100 shadow-sm transition-all duration-300 glass-safari">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      
      <!-- Logo Left -->
      <a href="/" class="flex-shrink-0 flex items-center gap-2 group">
        <div class="w-9 h-9 rounded-full bg-secondary flex items-center justify-center text-white font-heading font-bold text-lg transition-transform group-hover:scale-110">
          {config.clinicName.substring(0,2).toUpperCase()}
        </div>
        <span class="font-heading font-bold text-xl text-secondary tracking-tight">{config.clinicName}</span>
      </a>

      <!-- Desktop Menu Right -->
      <nav class="hidden md:flex items-center space-x-10">
        {config.navigation.map((link, idx) => (
          <a 
            href={link.href} 
            class={`text-sm font-semibold tracking-wide uppercase transition-colors ${idx === config.navigation.length - 1 ? 'text-primary' : 'text-gray-400 hover:text-secondary'}`}
          >
            {link.name}
          </a>
        ))}
      </nav>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button type="button" class="js-mobile-btn text-secondary focus:outline-none p-2" aria-label="Abrir menú">
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div class="js-mobile-menu hidden md:hidden bg-white fixed inset-0 z-50 flex flex-col items-center justify-center space-y-8 animate-in fade-in zoom-in duration-300">
    <!-- Close button for full screen mobile menu -->
    <button type="button" class="js-mobile-btn absolute top-6 right-6 text-secondary p-4">
      <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>

    {config.navigation.map(link => (
      <a href={link.href} class="text-3xl font-bold text-secondary hover:text-primary transition-colors">{link.name}</a>
    ))}
  </div>
</header>

<style is:global>
  .js-header {
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }
</style>

<script>
  const setupMinimalNavigation = () => {
    const btns = document.querySelectorAll('.js-mobile-btn');
    const menu = document.querySelector('.js-mobile-menu');
    
    if (menu) {
      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
          // Bloquear scroll cuando el menú minimalista (full screen) esté abierto
          document.body.classList.toggle('overflow-hidden');
        });
      });
    }
  };

  setupMinimalNavigation();
  document.addEventListener('astro:after-swap', setupMinimalNavigation);
</script>
