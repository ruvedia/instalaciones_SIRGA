---
import { config } from '../../data/config';
---
<!-- 
  🚀 REPARACIÓN TÉCNICA: 
  - Usamos 'header' como contenedor fixed principal (top-0) para máxima compatibilidad.
  - El 'pt-4' crea el espacio superior para el efecto visual de "isla".
  - Z-index 50 para asegurar que sea el elemento más alto de la página.
-->
<header class="js-header fixed top-0 left-0 w-full z-[100] transition-all duration-300 pointer-events-none pt-4">
  <div 
    id="pill-header"
    class="js-header w-[95%] max-w-7xl mx-auto bg-white/70 border border-white/20 shadow-2xl rounded-full px-6 py-3 flex items-center justify-center sm:justify-between pointer-events-auto transition-all duration-300 ring-1 ring-black/5 glass-safari animate-safari"
  >
    
    <!-- Logo & Marca -->
    <a href="/" class="flex items-center gap-2 group flex-shrink-0">
      <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center text-white font-heading font-bold text-xl transition-transform group-hover:scale-110">
        {config.clinicName.substring(0,2).toUpperCase()}
      </div>
      <span class="hidden sm:inline font-heading font-bold text-xl text-secondary tracking-tight">{config.clinicName}</span>
    </a>

    <!-- Navegación Central (Desktop) -->
    <nav class="hidden md:flex items-center space-x-10">
      {config.navigation.map(link => (
        <a href={link.href} class="text-xs font-bold uppercase tracking-[0.15em] text-gray-500 hover:text-primary transition-colors">
          {link.name}
        </a>
      ))}
    </nav>

    <!-- Acción & Menú Móvil -->
    <div class="flex items-center gap-4">
      <a href="/contacto" class="js-reserva-btn hidden sm:inline-flex items-center justify-center px-6 py-2.5 bg-accent text-white text-xs font-bold rounded-full shadow-lg shadow-accent/20 hover:scale-105 transition-all">
        Pedir Cita
      </a>

      <!-- Botón Móvil -->
      <button type="button" class="js-pill-mobile-btn md:hidden p-2 text-secondary focus:outline-none" aria-label="Menu">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Menú Móvil Desplegable (Relativo a la píldora) -->
    <div class="js-pill-mobile-menu hidden md:hidden absolute top-[115%] left-0 w-full bg-white/95 backdrop-blur-xl border border-gray-100 rounded-[2rem] shadow-2xl p-8 space-y-4 animate-in slide-in-from-top-2 duration-300 glass-safari animate-safari">
      {config.navigation.map(link => (
        <a href={link.href} class="block text-center text-secondary font-bold text-lg uppercase py-2 tracking-widest">{link.name}</a>
      ))}
      <a href="/contacto" class="block w-full text-center py-4 bg-accent text-white rounded-2xl font-bold mt-4">Reserva Cita</a>
    </div>
  </div>
</header>

<style is:global>
  #pill-header {
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }
</style>

<script>
  const setupPillRepair = () => {
    const mobileBtn = document.querySelector('.js-pill-mobile-btn');
    const mobileMenu = document.querySelector('.js-pill-mobile-menu');

    // 1. Eliminamos GSAP Reveal para evitar flickers en Safari.
    // El header es visible por CSS puro desde el primer frame.

    // 2. Lógica de Menú Móvil
    if (mobileBtn && mobileMenu) {
      mobileBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        mobileMenu.classList.toggle('hidden');
      });

      document.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    }
  };

  setupPillRepair();
  document.addEventListener('astro:after-swap', setupPillRepair);
</script>
