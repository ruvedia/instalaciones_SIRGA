---
import MainLayout from '../layouts/MainLayout.astro';
import Contact from '../components/Contact.astro';
import { config } from '../data/config';

let feedback = null;

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const name = data.get("name");
    const email = data.get("email");
    const reason = data.get("reason");
    const honeypot = data.get("address_2");
    const rgpdConsent = data.get("rgpd_consent");

    if (honeypot) {
      // Bot detectado por HoneyPot
      Astro.response.status = 400;
      feedback = { status: "error", message: "Petición bloqueada por reglas de seguridad." };
    } else if (!name || !email || !reason || String(name).length < 2) {
      Astro.response.status = 400;
      feedback = { status: "error", message: "Por favor, completa todos los campos requeridos correctamente." };
    } else if (!rgpdConsent) {
      Astro.response.status = 400;
      feedback = { status: "error", message: "Debes aceptar la Política de Privacidad para poder contactarnos." };
    } else {
      // Éxito. En un escenario real, aquí se envía el correo o se guarda en DB.
      Astro.response.status = 200;
      feedback = { status: "success", message: "¡Gracias por contactarnos! Nos comunicaremos contigo en breve." };
    }
  } catch (error) {
    console.error(error);
    Astro.response.status = 500;
    feedback = { status: "error", message: "Hubo un error en el servidor. Inténtalo de nuevo más tarde." };
  }
}
---

<MainLayout title={`Contacto | Instalaciones y Mantenimiento en ${config.contact.city} | ${config.clinicName}`} description={`Contacta con ${config.clinicName} (${config.contact.city}) para solicitar un presupuesto o información sobre nuestras instalaciones y servicios de mantenimiento.`}>
  
  <div class="pt-32 sm:pt-40 pb-8 bg-slate-50 text-center relative overflow-hidden">
    <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl opacity-50 -translate-y-1/2 translate-x-1/2"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-secondary mb-6">Contacta con Nosotros</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Rellena el formulario y nuestro departamento técnico se pondrá en contacto contigo para ofrecerte la mejor solución a tus necesidades.
      </p>
    </div>
  </div>

  {feedback && (
    <div class="bg-slate-50 relative z-20">
      <div class={`max-w-3xl mx-auto p-4 mb-4 rounded-xl text-center font-medium shadow-sm transition-all ${feedback.status === 'success' ? 'bg-green-100/80 text-green-800 border border-green-200' : 'bg-red-100/80 text-red-800 border border-red-200'}`}>
        {feedback.message}
      </div>
    </div>
  )}

  <Contact />

  <!-- Integración simulada de Google Maps -->
  <section class="bg-white max-w-7xl mx-auto px-4 pb-24">
    <div class="relative w-full h-[400px] bg-slate-200 rounded-[2.5rem] overflow-hidden shadow-inner border-4 border-slate-50 group">
      <!-- Mapa SVG de fondo (Placeholder interactivo) -->
      <div class="absolute inset-0 bg-[#e5e7eb] opacity-80" style="background-image: radial-gradient(#d1d5db 2px, transparent 2px); background-size: 30px 30px;"></div>
      
      <!-- Overlay Card -->
      <a href={config.contact.mapsUrl} aria-label={`Abrir mapa de Google de la ubicación de ${config.clinicName}`} target="_blank" rel="noopener noreferrer" class="absolute inset-0 flex items-center justify-center p-4 cursor-pointer focus:outline-none focus-visible:ring-4 focus-visible:ring-primary focus-visible:ring-inset">
        <div class="bg-white/95 backdrop-blur px-8 py-5 rounded-2xl shadow-xl border border-gray-100 flex flex-col items-center gap-3 group-hover:scale-105 transition-transform duration-300">
          <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary mb-1">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <span class="font-bold text-secondary text-lg">Ubicación de {config.clinicName}</span>
          <span class="text-sm text-gray-500">Haz clic para abrir en Google Maps</span>
        </div>
      </a>
    </div>
  </section>

</MainLayout>
