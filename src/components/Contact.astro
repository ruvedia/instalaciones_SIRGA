---
import { config } from '../data/config';
---
<section id="contacto" class="py-12 bg-white relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      
      <!-- Text Info Side -->
      <div class="flex flex-col justify-center">
        <h2 class="text-4xl md:text-5xl font-bold text-secondary mb-6 leading-tight">
          ¿Listo para empezar a <br/><span class="text-primary">mejorar tu vida?</span>
        </h2>
        <p class="text-gray-600 text-lg mb-10 max-w-md leading-relaxed">
          Escríbenos indicando tu caso y nuestro equipo te contactará rápidamente para organizar tu primera sesión y comenzar con tu plan de recuperación.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-2xl border border-gray-100 hover:border-primary/30 transition-colors">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-4">
               <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <h4 class="font-bold text-secondary text-lg mb-1">Email</h4>
            <p class="text-primary hover:text-secondary transition-colors"><a href={`mailto:${config.contact.email}`}>{config.contact.email}</a></p>
          </div>
          <div class="bg-white p-6 rounded-2xl border border-gray-100 hover:border-primary/30 transition-colors">
            <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center text-primary mb-4">
               <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </div>
            <h4 class="font-bold text-secondary text-lg mb-1">Teléfono</h4>
            <p class="text-primary hover:text-secondary transition-colors"><a href={`tel:${config.contact.phone.replace(/\s+/g, '')}`}>{config.contact.phone}</a></p>
          </div>
        </div>
      </div>

      <div class="animate-safari bg-white p-8 sm:p-10 rounded-[2.5rem] shadow-[0_8px_30px_rgb(0,0,0,0.08)] border border-gray-100 relative">
        <form class="space-y-6" method="POST" action="/contacto">
          <!-- Honeypot oculto para bots -->
          <div class="hidden" aria-hidden="true">
            <label for="address_2">No rellenar si eres humano</label>
            <input type="text" id="address_2" name="address_2" tabindex="-1" autocomplete="off" />
          </div>

          <div>
            <label for="name" class="block text-sm font-semibold text-secondary mb-2">Nombre completo</label>
            <input type="text" id="name" name="name" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary focus:border-primary transition-colors outline-none text-gray-700 bg-gray-50 transform-gpu" placeholder="Ej. Juan Pérez" required>
          </div>
          
          <div>
            <label for="email" class="block text-sm font-semibold text-secondary mb-2">Correo electrónico</label>
            <input type="email" id="email" name="email" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary focus:border-primary transition-colors outline-none text-gray-700 bg-gray-50 transform-gpu" placeholder="tu@email.com" required>
          </div>
          
          <div>
            <label for="reason" class="block text-sm font-semibold text-secondary mb-2">Motivo de consulta</label>
            <textarea id="reason" name="reason" rows="4" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary focus:border-primary transition-colors outline-none text-gray-700 bg-gray-50 transform-gpu resize-none" placeholder="Cuéntanos brevemente qué necesitas..." required></textarea>
          </div>
          
          <div class="flex items-start gap-3">
            <div class="flex items-center h-5">
              <input id="rgpd_consent" name="rgpd_consent" type="checkbox" required class="w-4 h-4 text-primary bg-gray-50 transform-gpu border-gray-300 rounded focus:ring-2 focus:ring-primary/50 cursor-pointer">
            </div>
            <div class="text-sm">
              <label for="rgpd_consent" class="font-medium text-gray-600 cursor-pointer">
                He leído y acepto la <a href="/politica-de-privacidad" class="text-primary hover:underline transition-colors" target="_blank">Política de Privacidad</a>.
              </label>
            </div>
          </div>
          
          <button type="submit" class="js-reserva-btn w-full py-4 px-6 border border-transparent text-lg font-bold rounded-xl text-white bg-accent hover:bg-accent-hover shadow-lg shadow-accent/20 transition-all">
            Enviar Mensaje
          </button>
          
          <p class="text-xs text-gray-400 text-center mt-6">
            Al enviar este formulario aceptas nuestra política de privacidad.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>
