---
import { config } from '../data/config';
---

<!-- Cookies Floating Button (Bottom Left) -->
<div class="fixed bottom-6 left-6 z-[999] group">
  <button 
    id="cookie-trigger"
    class="w-14 h-14 bg-white border border-gray-200 rounded-full shadow-2xl flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all duration-300 active:scale-95"
    aria-label="Gestionar Cookies"
  >
        <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5Z"/>
          <path d="M8.5 8.5v.01"/>
          <path d="M16 15.5v.01"/>
          <path d="M12 12v.01"/>
          <path d="M11 17v.01"/>
          <path d="M7 14v.01"/>
        </svg>
  </button>
  
  <!-- Tooltip -->
  <span class="absolute left-full ml-4 top-1/2 -translate-y-1/2 px-3 py-1 bg-secondary text-white text-xs font-bold rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg">
    Cookies
  </span>
</div>

<!-- Contact Floating Buttons (Bottom Right) -->
<div class="fixed bottom-6 right-6 z-[999] flex flex-col gap-4">
  <!-- Call Button -->
  <a 
    href={`tel:${config.contact.phone}`}
    class="w-14 h-14 bg-primary text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-300 relative group"
    aria-label="Llamar directamente"
  >
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 111.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    <span class="absolute right-full mr-4 top-1/2 -translate-y-1/2 px-3 py-1 bg-secondary text-white text-xs font-bold rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg">
      Llámanos
    </span>
  </a>

  <!-- Email Button -->
  <a 
    href={`mailto:${config.contact.email}`}
    class="w-14 h-14 rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all duration-300 relative group"
    style="background-color: #F58220; color: #FFFFFF;"
    aria-label="Enviar correo electrónico"
  >
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
    <span class="absolute right-full mr-4 top-1/2 -translate-y-1/2 px-3 py-1 bg-secondary text-white text-xs font-bold rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg">
      Email
    </span>
  </a>
</div>

<script>
  // Simple trigger for the existing Cookie Banner (if available)
  const trigger = document.getElementById('cookie-trigger');
  
  if (trigger) {
    trigger.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('toggle-cookies'));
    });
  }
</script>
