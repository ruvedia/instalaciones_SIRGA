---
import { config } from '../../data/config';
import { Picture } from 'astro:assets';
---
<section class="relative bg-white min-h-[100svh] !important w-full flex !important flex-col !important justify-start !important items-center !important p-0 !important m-0 !important pt-[180px] sm:pt-[200px] !important pb-10 !important box-border !important overflow-hidden z-[1]" style="-webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full animate-fade-up">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
      
      <!-- Interactive Image Side (First on Mobile) -->
      <div class="relative group animate-fade-up order-1 lg:order-2" style="animation-delay: 0.2s;">
        <div class="absolute -inset-4 rounded-[4rem] blur-2xl group-hover:bg-primary/10 transition-colors duration-700" style="background-color: rgba(0,119,182,0.05) !important;"></div>
        <div class="relative aspect-[4/5] sm:aspect-square lg:aspect-[4/5] rounded-[3.5rem] overflow-hidden shadow-2xl border-8 border-white">
          <img 
            src="/images/instalaciones-sirga-hero.png" 
            width="1024"
            height="1024"
            alt="Instalaciones Sirga" 
            class="w-full h-full object-cover"
            style="image-rendering: -webkit-optimize-contrast; width: 100% !important; height: 100% !important;"
          />
        </div>
      </div>

      <!-- Text Side (Second on Mobile) -->
      <div class="relative z-10 order-2 lg:order-1">
        <span class="animate-safari inline-block py-1.5 px-4 rounded-full font-semibold mb-8 border border-primary/20 tracking-wide uppercase" style="background-color: rgba(245, 130, 32, 0.1) !important; color: #F58220 !important; font-size: 14px !important; line-height: 20px !important;">
          {config.hero.badge}
        </span>
        
        <h1 class="animate-safari font-bold tracking-tight mb-8 leading-[1.1] text-balance" style="color: #1a1a1a !important; font-size: clamp(32px, 6vw, 70px) !important; line-height: 1.1 !important;">
          <Fragment set:html={config.hero.title} />
        </h1>
        
        <p class="animate-safari mb-10 leading-relaxed text-balance" style="color: #4B5563 !important; font-size: 20px !important; line-height: 32px !important;">
          {config.hero.description}
        </p>
        
        <div class="animate-safari flex flex-col sm:flex-row items-center gap-4">
          <a href="/contacto" class="js-reserva-btn inline-flex items-center justify-center px-8 py-4 border border-transparent font-semibold rounded-full shadow-lg shadow-primary/30 w-full sm:w-auto" style="background-color: #F58220 !important; color: #FFFFFF !important; font-size: 16px !important;">
            Contactar Ahora
          </a>
          <a href="/servicios" class="inline-flex items-center justify-center px-8 py-4 border border-gray-200 font-semibold rounded-full bg-white hover:bg-gray-50 shadow-sm transition-all duration-300 w-full sm:w-auto" style="color: #1a1a1a !important; font-size: 16px !important;">
            Descubrir Más
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  .hero-inter-active {
    opacity: 1 !important;
    visibility: visible !important;
  }
</style>

<script>
  import { gsap } from "gsap";

  // Efecto de flotación perpetua (Mantenemos por ser decorativo y no afectar visibilidad inicial)
  const image = document.querySelector(".js-inter-image");
  if (image) {
    gsap.to(image, {
      y: -15,
      rotation: 1,
      duration: 3,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });
  }

  // Elementos UI flotantes con desfase
  const floaters = document.querySelectorAll(".js-float-ui");
  floaters.forEach((ui, i) => {
    gsap.to(ui, {
      y: 10,
      x: i % 2 === 0 ? 5 : -5,
      duration: 2.5 + i,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: i * 0.5
    });
  });

  // Eliminamos GSAP Reveal para evitar flickers en Safari.
</script>
