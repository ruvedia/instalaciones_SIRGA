---
import { config } from '../../data/config';
---
<section class="relative min-h-[100svh] !important w-full flex !important flex-col !important justify-start !important items-center !important overflow-hidden m-0 !important pt-[180px] sm:pt-[200px] !important pb-10 !important box-border !important z-[1] bg-[#1a1a1a] border-b-[12px] border-primary" style="-webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;">
  
  <!-- Background Image with Robust Overlay -->
  <div class="absolute inset-0 -z-10 isolate overflow-hidden m-0 p-0">
    <img 
      src={config.hero.image} 
      alt="Instalaciones Sirga SL - Vanguardia en instalaciones" 
      class="w-full h-full object-cover object-center m-0 p-0"
      style="image-rendering: -webkit-optimize-contrast; width: 100% !important; height: 100% !important;"
      loading="eager"
    />
    <!-- Overlay negro suavizado para que la imagen se vea más clara -->
    <div class="absolute inset-0 bg-black opacity-20 pointer-events-none"></div>
    <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(0deg, rgba(26,26,26,0.5) 0%, rgba(26,26,26,0.1) 100%);"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 animate-fade-up w-full">
    <div class="text-center max-w-4xl mx-auto">
      <span class="animate-safari inline-block py-2 px-6 rounded-full bg-white/10 backdrop-blur-md font-semibold mb-8 border border-white/20 tracking-widest uppercase glass-safari" style="color: #FFFFFF !important; font-size: 14px !important; line-height: 20px !important;">
        {config.hero.badge}
      </span>
      
      <h1 class="animate-safari font-bold tracking-tight mb-8 text-balance drop-shadow-2xl" style="color: #FFFFFF !important; font-size: clamp(40px, 8vw, 90px) !important; line-height: 1.1 !important;">
        <Fragment set:html={config.hero.title} />
      </h1>
      
      <p class="animate-safari mb-12 text-balance font-light drop-shadow" style="color: #F3F4F6 !important; font-size: 24px !important; line-height: 36px !important;">
        {config.hero.description}
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
        <a href="/contacto" class="group relative inline-flex items-center justify-center px-10 py-5 bg-primary text-white font-bold rounded-full shadow-2xl shadow-primary/40 overflow-hidden transition-all hover:scale-105 hover:bg-primary-light ring-1 ring-white/20 w-full sm:w-auto js-reserva-btn" style="color: #FFFFFF !important; font-size: 18px !important;">
          <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-shine pointer-events-none"></span>
          <span class="relative z-10">Solicitar Presupuesto</span>
        </a>

        <a href="/servicios" class="group relative inline-flex items-center justify-center px-10 py-5 bg-white text-secondary font-bold rounded-full shadow-xl transition-all duration-300 hover:scale-105 hover:bg-gray-50 w-full sm:w-auto overflow-hidden" style="color: #1a1a1a !important; font-size: 18px !important;">
          <span class="relative z-10">Ver Servicios</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* Visibilidad forzada y normalización total */
  .hero-background-active {
    opacity: 1 !important;
    visibility: visible !important;
  }
</style>

<style>
  @keyframes shine {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
  }
  .group:hover .group-hover\:animate-shine {
    animation: shine 0.8s ease-in-out;
  }
  .hero-highlight {
    color: var(--primary-color, var(--color-primary));
  }
</style>

<script>
  // Eliminamos GSAP Reveal para evitar flickers en Safari. 
  // El contenido ya es visible por CSS puro.
</script>
