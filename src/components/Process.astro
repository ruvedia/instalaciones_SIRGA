---
const steps = [
  {
    number: "01",
    title: "Contacto",
    description: "Atención inmediata y personalizada para entender sus necesidades técnicas.",
    icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
  },
  {
    number: "02",
    title: "Visita y Presupuesto",
    description: "Evaluación técnica presencial y elaboración de propuesta detallada sin compromiso.",
    icon: "M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
  },
  {
    number: "03",
    title: "Ejecución",
    description: "Instalación profesional bajo estrictos estándares de calidad y seguridad industrial.",
    icon: "M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 011-1h1a2 2 0 100-4H7a1 1 0 01-1-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"
  },
  {
    number: "04",
    title: "Entrega y Garantía",
    description: "Puesta en marcha, entrega de certificaciones y garantía total de funcionamiento.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
  }
];
---

<section class="py-12 bg-secondary overflow-hidden relative">
  <!-- Decorative background element -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-primary/5 -skew-x-12 transform translate-x-1/3"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-20">
      <h2 class="font-bold tracking-widest uppercase text-sm mb-4" style="color: #F58220;">Metodología de Trabajo</h2>
      <h3 class="text-4xl md:text-5xl font-bold text-white mb-6">Nuestro Proceso de Ingeniería</h3>
      <p class="text-gray-400 max-w-2xl mx-auto">Un flujo de trabajo optimizado para garantizar la máxima eficiencia en cada fase del proyecto.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="relative group">
          <!-- Connector Line (Desktop) -->
          {index < steps.length - 1 && (
            <div class="hidden lg:block absolute top-12 left-full w-full h-px bg-gradient-to-r from-primary/50 to-transparent z-0 -translate-x-10"></div>
          )}
          
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 p-8 rounded-3xl hover:bg-white/10 transition-all duration-500 hover:-translate-y-2 relative z-10">
            <div class="flex items-center justify-between mb-6">
              <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center text-white shadow-lg shadow-primary/20">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.icon} />
                </svg>
              </div>
              <span class="text-4xl font-bold text-white/10 group-hover:text-primary/20 transition-colors">{step.number}</span>
            </div>
            <h4 class="text-xl font-bold text-white mb-4">{step.title}</h4>
            <p class="text-gray-400 text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
