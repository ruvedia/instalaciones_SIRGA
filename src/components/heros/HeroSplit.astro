---
import { config } from '../../data/config';
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/hero.png';
---
<section class="relative bg-white min-h-[80vh] w-full flex flex-col justify-start items-center pt-[140px] sm:pt-[180px] pb-0 box-border overflow-hidden z-[1]" style="-webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      
      <!-- Text Content with CSS Animation (First on Desktop) -->
      <div class="max-w-2xl relative z-10 animate-fade-up order-2 lg:order-1">
        <span class="animate-safari inline-block py-1.5 px-4 rounded-full font-semibold mb-6 border border-primary/20 tracking-wide uppercase" style="background-color: rgba(0,36,125,0.1) !important; color: #00247D !important; font-size: 14px !important; line-height: 20px !important;">
          {config.hero.badge}
        </span>
        <h1 class="animate-safari font-bold tracking-tight mb-6 leading-[1.1] text-balance" style="color: #1a1a1a !important; font-size: clamp(32px, 5vw, 60px) !important; line-height: 1.1 !important;">
          <Fragment set:html={config.hero.title} />
        </h1>
        <p class="animate-safari mb-8 leading-relaxed text-balance" style="color: #4B5563 !important; font-size: 20px !important; line-height: 32px !important;">
          {config.hero.description}
        </p>
        
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4">
          <a href="/contacto" class="js-reserva-btn inline-flex items-center justify-center px-8 py-4 border border-transparent font-semibold rounded-full shadow-lg shadow-primary/30 w-full sm:w-auto" style="background-color: #00247D !important; color: #FFFFFF !important; font-size: 16px !important;">
            Solicitar Presupuesto
          </a>
          <a href="/servicios" class="inline-flex items-center justify-center px-8 py-4 border border-gray-200 font-semibold rounded-full bg-white hover:bg-gray-50 shadow-sm transition-all duration-300 w-full sm:w-auto" style="color: #1a1a1a !important; font-size: 16px !important;">
            Ver Servicios
          </a>
        </div>
      </div>

      <!-- Image Column (Second on Desktop) -->
      <div class="relative animate-fade-up order-1 lg:order-2 group" style="animation-delay: 0.2s;">
        <div class="absolute -inset-4 bg-primary/5 rounded-[4rem] -rotate-2 group-hover:rotate-0 transition-transform duration-700"></div>
        <div class="relative h-full w-full rounded-[3.5rem] overflow-hidden shadow-2xl border-8 border-white ring-1 ring-gray-100 aspect-[4/3] lg:aspect-auto lg:h-[550px]">
          <Image 
            src={heroImg} 
            alt="Instalaciones Sirga SL" 
            class="w-full h-full object-contain bg-slate-50 transform hover:scale-105 transition-transform duration-1000"
            style="image-rendering: auto; width: 100% !important; height: 100% !important;"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/5 to-transparent pointer-events-none"></div>
        </div>
        <!-- Decorative element -->
        <div class="absolute -bottom-8 -right-8 w-40 h-40 rounded-full bg-primary/10 blur-3xl"></div>
      </div>
      
    </div>
  </div>
</section>

<style is:global>
  .hero-split-active {
    opacity: 1 !important;
    visibility: visible !important;
  }
</style>

<script>
  // Eliminamos GSAP Reveal para evitar flickers en Safari. 
  // El contenido ya es visible por CSS puro desde el servidor.
</script>
