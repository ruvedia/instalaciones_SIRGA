---
import { config } from '../../data/config';
import { Image } from 'astro:assets';
import logoSirga from '../../assets/images/logo.jpg';
---
<header class="js-header fixed top-0 left-0 w-full z-[100] bg-white/95 backdrop-blur-md border-b border-gray-100 shadow-sm transition-all duration-300 glass-safari">
  <!-- Top Bar Informativa -->
  <div class="hidden sm:block border-b border-gray-50 bg-slate-50/50 py-2">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center text-xs font-medium text-gray-500 tracking-wide">
      <div class="flex items-center gap-6">
        <a href={`tel:${config.contact.phone}`} class="flex items-center gap-2 hover:text-primary transition-colors">
          <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 111.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          {config.contact.phone}
        </a>
        <div class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          {config.schedule[0].day}: {config.schedule[0].hours}
        </div>
      </div>
      <div class="flex items-center gap-4 uppercase font-bold text-[10px]">
        Ubicación: <span class="text-secondary">{config.contact.city}</span>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo Left -->
      <a href="/" class="flex-shrink-0 flex items-center gap-4 cursor-pointer group">
        <Image 
          src={logoSirga} 
          alt="Logo Instalaciones Sirga SL" 
          width={180}
          class="h-12 w-auto object-contain"
        />
      </a>

      <!-- Desktop Menu Center -->
      <nav class="hidden md:flex space-x-8">
        {config.navigation.map(link => (
          <a href={link.href} class="text-gray-600 hover:text-primary transition-colors font-medium">{link.name}</a>
        ))}
      </nav>

      <!-- CTA Right -->
      <div class="hidden md:block">
        <a href="/contacto" class="js-reserva-btn inline-flex items-center justify-center px-6 py-2.5 border border-transparent text-sm font-medium rounded-full text-white bg-primary hover:bg-primary-dark shadow-md shadow-primary/30 transition-colors">
          Solicitar Presupuesto
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button type="button" class="js-mobile-btn text-gray-600 hover:text-primary focus:outline-none p-2" aria-label="Abrir menú">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div class="js-mobile-menu hidden md:hidden bg-white border-t border-gray-100 p-6 space-y-4 shadow-xl">
    {config.navigation.map(link => (
      <a href={link.href} class="block text-gray-700 hover:text-primary transition-colors font-semibold py-2 text-lg border-b border-gray-50">{link.name}</a>
    ))}
    <a href="/contacto" class="block w-full text-center py-4 bg-primary text-white rounded-xl font-bold mt-4 shadow-md shadow-primary/30">Solicitar Presupuesto</a>
  </div>
</header>

<style is:global>
  .js-header {
    opacity: 1 !important;
    visibility: visible !important;
    transform: none !important;
  }
</style>

<script>
  // Script compartido para navegación móvil (encapsulado en el componente)
  const setupNavigation = () => {
    const btn = document.querySelector('.js-mobile-btn');
    const menu = document.querySelector('.js-mobile-menu');
    
    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  };

  // Ejecutar al cargar y tras transiciones si se usa ViewTransitions
  setupNavigation();
  document.addEventListener('astro:after-swap', setupNavigation);
</script>
