---
const { testimonials } = Astro.props;
---

<section class="py-12 bg-secondary overflow-hidden">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    
    <!-- Comillas Decorativas -->
    <div class="absolute -top-10 left-0 text-[10rem] font-serif text-white/5 select-none leading-none">“</div>
    
    <div class="relative z-10 text-center text-white mb-12">
      <h2 class="text-3xl font-heading font-bold mb-2">Historias de éxito</h2>
      <div class="w-12 h-1 bg-accent mx-auto"></div>
    </div>

    <div class="js-testimonial-slider animate-safari relative min-h-[400px] flex items-center justify-center translate-y-10 opacity-0">
      {testimonials && testimonials.map((test, index) => (
        <div class={`js-slide animate-safari absolute inset-0 flex flex-col items-center justify-center text-center ${index === 0 ? 'opacity-100' : 'opacity-0 invisible'}`}>
          
          <!-- Google Icon for Slider -->
          <div class="mb-6">
            <svg class="w-8 h-8 mx-auto" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-1 .67-2.28 1.07-3.71 1.07-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.11c-.22-.66-.35-1.36-.35-2.11s.13-1.45.35-2.11V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.83z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.83c.87-2.6 3.3-4.51 6.16-4.51z" fill="#EA4335"/>
            </svg>
          </div>

          <blockquote class="text-2xl md:text-3xl font-heading italic text-white/90 leading-relaxed max-w-3xl mb-10">
            "{test.comentario}"
          </blockquote>
          
          <div class="flex flex-col items-center">
            {test.foto && (
              <img src={test.foto} alt={test.nombre} class="w-20 h-20 rounded-full object-cover border-4 border-white/10 mb-4" />
            )}
            <h4 class="text-xl font-bold text-white leading-tight">{test.nombre}</h4>
            <span class="text-sm text-accent font-medium uppercase tracking-widest">{test.puesto}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Navigation -->
    <div class="flex items-center justify-center gap-6 mt-12">
      <button class="js-prev-testimonial p-3 rounded-full border border-white/20 text-white hover:bg-white/10 transition-colors">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      </button>
      
      <div class="flex gap-2">
        {testimonials && testimonials.map((_, i) => (
          <div class={`js-dot w-2.5 h-2.5 rounded-full border border-white/40 ${i === 0 ? 'bg-accent border-accent' : ''}`}></div>
        ))}
      </div>

      <button class="js-next-testimonial p-3 rounded-full border border-white/20 text-white hover:bg-white/10 transition-colors">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
      </button>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const setupSlider = () => {
    const sliderContainer = document.querySelector('.js-testimonial-slider');
    
    // Entrance Anim
    if (sliderContainer) {
      gsap.to(sliderContainer, {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power3.out",
        force3D: true,
        scrollTrigger: {
          trigger: sliderContainer,
          start: "top 80%",
        }
      });
    }

    const slides = document.querySelectorAll('.js-slide');
    const dots = document.querySelectorAll('.js-dot');
    const nextBtn = document.querySelector('.js-next-testimonial');
    const prevBtn = document.querySelector('.js-prev-testimonial');
    
    let currentIndex = 0;
    let isAnimating = false;

    const goToSlide = (index) => {
      if (isAnimating || index === currentIndex) return;
      isAnimating = true;

      const outgoing = slides[currentIndex];
      const incoming = slides[index];

      const tl = gsap.timeline({
        defaults: { force3D: true },
        onComplete: () => {
          isAnimating = false;
          currentIndex = index;
        }
      });

      // Outgoing logic
      tl.to(outgoing, { opacity: 0, scale: 0.95, y: -20, duration: 0.4, ease: "power2.in" });
      tl.set(outgoing, { visibility: 'hidden' });

      // Incoming logic
      tl.set(incoming, { visibility: 'visible', y: 20, scale: 1.05 });
      tl.to(incoming, { opacity: 1, scale: 1, y: 0, duration: 0.6, ease: "power2.out" });

      // Dots
      dots.forEach((dot, i) => {
        if (i === index) dot.classList.add('bg-accent', 'border-accent');
        else dot.classList.remove('bg-accent', 'border-accent');
      });
    };

    nextBtn?.addEventListener('click', () => {
      let next = (currentIndex + 1) % slides.length;
      goToSlide(next);
    });

    prevBtn?.addEventListener('click', () => {
      let prev = (currentIndex - 1 + slides.length) % slides.length;
      goToSlide(prev);
    });

    // Auto-play opcional
    // setInterval(() => nextBtn?.click(), 8000);
  };

  setupSlider();
  document.addEventListener('astro:after-swap', setupSlider);
</script>
