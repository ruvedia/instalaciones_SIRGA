---
const { testimonials } = Astro.props;
---

<section class="py-12 bg-white border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-heading font-extrabold text-secondary mb-4">Lo que dicen nuestros pacientes</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">La confianza es la base de nuestra recuperación. Conoce las experiencias reales en FisioDynamics.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials && testimonials.map((test) => (
        <div class="js-testimonial-card animate-safari opacity-0 bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-2 transition-all duration-300 flex flex-col justify-between relative overflow-hidden group">
          <!-- Google 'G' Logo -->
          <div class="absolute top-4 right-4 opacity-20 group-hover:opacity-100 transition-opacity">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-1 .67-2.28 1.07-3.71 1.07-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.11c-.22-.66-.35-1.36-.35-2.11s.13-1.45.35-2.11V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.83z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.83c.87-2.6 3.3-4.51 6.16-4.51z" fill="#EA4335"/>
            </svg>
          </div>

          <div>
            <!-- Estrellas -->
            <div class="flex gap-1 mb-6">
              {[...Array(5)].map((_, i) => (
                <svg 
                  class={`w-5 h-5 ${i < test.estrellas ? 'text-yellow-400 fill-current' : 'text-gray-200'}`} 
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            
            <p class="text-gray-700 italic leading-relaxed mb-8">"{test.comentario}"</p>
          </div>

          <div class="flex items-center gap-4">
            {test.foto && (
              <img 
                src={test.foto} 
                alt={test.nombre} 
                class="w-12 h-12 rounded-full object-cover ring-2 ring-primary/20"
              />
            )}
            <div>
              <h4 class="font-bold text-secondary">{test.nombre}</h4>
              <p class="text-xs text-primary font-semibold uppercase tracking-wider">{test.puesto}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const setupGridAnimations = () => {
    gsap.to(".js-testimonial-card", {
      opacity: 1,
      scale: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: "back.out(1.7)",
      force3D: true,
      scrollTrigger: {
        trigger: ".js-testimonial-card",
        start: "top 85%",
        toggleActions: "play none none none"
      }
    });
  };

  setupGridAnimations();
  document.addEventListener('astro:after-swap', setupGridAnimations);
</script>
