---
const { testimonials } = Astro.props;
// Suponemos que tenemos al menos 3
---

<section class="py-12 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
      <div class="max-w-xl">
        <h2 class="text-4xl md:text-5xl font-heading font-extrabold text-secondary mb-4 leading-tight">Tu recuperación es nuestra <span class="text-primary italic">mayor satisfacción.</span></h2>
      </div>
      <p class="text-gray-500 max-w-xs text-sm">Más de 500 pacientes confían en FisioDynamics cada año para recuperar su movilidad.</p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 grid-rows-none md:grid-rows-2 gap-4 h-full md:h-[600px]">
      
      <!-- Card 1: Principal (Grande) -->
      <div class="js-bento-card animate-safari opacity-0 md:col-span-8 md:row-span-2 bg-primary rounded-[2.5rem] p-10 flex flex-col justify-between text-white relative overflow-hidden group">
        <!-- Google 'G' Logo Overlay -->
        <div class="absolute top-8 right-16 opacity-30 group-hover:opacity-100 transition-opacity">
            <svg class="w-8 h-8" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-1 .67-2.28 1.07-3.71 1.07-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.11c-.22-.66-.35-1.36-.35-2.11s.13-1.45.35-2.11V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.83z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.83c.87-2.6 3.3-4.51 6.16-4.51z" fill="#EA4335"/>
            </svg>
        </div>

        <div class="absolute top-0 right-0 p-8 text-8xl font-serif text-white/10 group-hover:scale-110 transition-transform">“</div>
        
        <div class="relative z-10">
          <div class="flex gap-1 mb-6">
            {testimonials[0] && [...Array(5)].map((_, i) => (
              <svg class="w-6 h-6 text-accent fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>
          <p class="text-2xl md:text-4xl font-heading font-medium leading-tight">
            "{testimonials[0]?.comentario}"
          </p>
        </div>

        <div class="flex items-center gap-4 mt-8 relative z-10">
          <img src={testimonials[0]?.foto} class="w-16 h-16 rounded-2xl object-cover" alt={testimonials[0]?.nombre} />
          <div>
            <h4 class="text-xl font-bold">{testimonials[0]?.nombre}</h4>
            <span class="text-sm text-white/70">{testimonials[0]?.puesto}</span>
          </div>
        </div>
      </div>

      <!-- Card 2: Secundaria (Top Right) -->
      <div class="js-bento-card animate-safari opacity-0 md:col-span-4 bg-slate-100 rounded-[2rem] p-8 flex flex-col justify-between hover:bg-slate-200 transition-colors relative group">
        <!-- Google Overlay -->
        <div class="absolute top-4 right-4 opacity-10 group-hover:opacity-100 transition-opacity">
            <svg class="w-4 h-4" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-1 .67-2.28 1.07-3.71 1.07-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.11c-.22-.66-.35-1.36-.35-2.11s.13-1.45.35-2.11V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.83z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.83c.87-2.6 3.3-4.51 6.16-4.51z" fill="#EA4335"/>
            </svg>
        </div>
        <p class="text-gray-700 font-medium leading-relaxed mb-6 italic">"{testimonials[1]?.comentario}"</p>
        <div class="flex items-center gap-3">
          <img src={testimonials[1]?.foto} class="w-10 h-10 rounded-full object-cover grayscale hover:grayscale-0 transition-all" alt={testimonials[1]?.nombre} />
          <div>
            <h4 class="font-bold text-secondary text-sm">{testimonials[1]?.nombre}</h4>
            <span class="text-[10px] uppercase font-bold text-primary">{testimonials[1]?.puesto}</span>
          </div>
        </div>
      </div>

      <!-- Card 3: Secundaria (Bottom Right) -->
      <div class="js-bento-card animate-safari opacity-0 md:col-span-4 bg-accent rounded-[2rem] p-8 flex flex-col justify-between text-white relative group">
        <!-- Google Overlay -->
        <div class="absolute top-4 right-4 opacity-30 group-hover:opacity-100 transition-opacity">
            <svg class="w-4 h-4" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-1 .67-2.28 1.07-3.71 1.07-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.11c-.22-.66-.35-1.36-.35-2.11s.13-1.45.35-2.11V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.83z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.83c.87-2.6 3.3-4.51 6.16-4.51z" fill="#EA4335"/>
            </svg>
        </div>
        <p class="font-bold leading-tight mb-4 text-secondary-dark">"{testimonials[2]?.comentario}"</p>
        <div class="flex items-center justify-between">
            <div class="flex flex-col">
                <h4 class="font-black italic text-xs uppercase">{testimonials[2]?.nombre}</h4>
                <span class="text-[10px] opacity-80">{testimonials[2]?.puesto}</span>
            </div>
            <div class="flex">
                {testimonials[2] && [...Array(testimonials[2].estrellas)].map(() => (
                    <svg class="w-3 h-3 text-white fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
            </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const setupBentoAnimations = () => {
    gsap.to(".js-bento-card", {
      opacity: 1,
      scale: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: "elastic.out(1, 0.75)",
      force3D: true,
      scrollTrigger: {
        trigger: ".js-bento-card",
        start: "top 85%",
      }
    });
  };

  setupBentoAnimations();
  document.addEventListener('astro:after-swap', setupBentoAnimations);
</script>
